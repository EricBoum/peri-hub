{
  "name": "peri-hub",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform desktop peripheral hub for monitor and device management (Tauri + React + Rust).",
  "keywords": [
    "tauri",
    "rust",
    "react",
    "desktop-app",
    "cross-platform",
    "monitor-control",
    "brightness-control",
    "ddc-ci",
    "macos",
    "windows",
    "peripheral-manager"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "gen:dmg-bg": "swift scripts/generate-dmg-background.swift",
    "export:dmg": "bash scripts/export-dmg.sh",
    "build:mac": "tauri build --bundles app,dmg",
    "release:mac": "pnpm build:mac && pnpm export:dmg",
    "build:win": "tauri build --bundles nsis,msi",
    "build:all": "pnpm build:mac && pnpm build:win"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.2",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
